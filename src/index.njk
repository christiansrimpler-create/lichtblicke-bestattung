---
layout: layout.njk
active: start
title: Würdevolle Bestattung zu fairen Preisen
desc: Lichtblicke Bestattung in Freiburg – einfühlsame, transparente und bezahlbare Bestattungen für jeden Menschen. 24 Stunden telefonisch erreichbar.
---
{% set s = seiten.start %}
<section class="hero">
  <div class="hero-bg" style="background-image: url('{{ s.hero.bild | url }}');"></div>
  <div class="wrap hero-inner">
    <p class="kicker reveal">{{ s.hero.kicker }}</p>
    <h1 class="reveal">{{ einstellungen.claim }}</h1>
    <p class="hero-lead reveal">{{ einstellungen.hero_text }}</p>
    <div class="hero-actions reveal">
      <a class="btn btn-primary" href="{{ '/preise/' | url }}">{{ s.hero.cta_preise }}</a>
      <a class="btn btn-ghost" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }} anrufen</a>
    </div>
    <p class="hero-note reveal">{{ einstellungen.erreichbarkeit }}</p>
  </div>
</section>

<section class="band-quiet">
  <div class="wrap narrow reveal">
    <p class="quote-kicker">{{ s.gedicht.kicker }}</p>
    <blockquote class="poem">
      {{ s.gedicht.zeilen | join("<br>") | safe }}
    </blockquote>
    <div class="horizon horizon--dark" aria-hidden="true"></div>
    <p class="poem-after">{{ s.gedicht.nachsatz }}</p>
  </div>
</section>

<section class="section section-tint">
  <div class="wrap narrow center reveal">
    <p class="eyebrow">{{ s.schritte.eyebrow }}</p>
    <h2>{{ s.schritte.titel }}</h2>
    <p class="lead">{{ s.schritte.lead }}</p>
  </div>

  <div class="wrap schritte">
    {%- for punkt in s.schritte.punkte %}
    <article class="schritt reveal">
      <span class="schritt-num">{{ loop.index }}</span>
      <h3>{{ punkt.titel }}</h3>
      <p>{{ punkt.text }}</p>
    </article>
    {%- endfor %}
  </div>

  <div class="wrap center reveal">
    <a class="btn btn-primary" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }} anrufen</a>
  </div>
</section>

<section class="section">
  <div class="wrap reveal">
    <div class="narrow-left">
      <p class="eyebrow">{{ s.werte.eyebrow }}</p>
      <h2>{{ s.werte.titel }}</h2>
      <p class="lead">{{ s.werte.lead }}</p>
    </div>
  </div>

  <div class="wrap werte-grid">
    <article class="werte-item reveal">
      <span class="werte-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path pathLength="1" d="M3.5 11.2 11.4 3.3a1 1 0 0 1 .7-.3H19a1.5 1.5 0 0 1 1.5 1.5v6.9a1 1 0 0 1-.3.7l-7.9 7.9a1.5 1.5 0 0 1-2.1 0l-6.7-6.7a1.5 1.5 0 0 1 0-2.1Z"/><circle pathLength="1" cx="16" cy="8" r="1.4"/></svg>
      </span>
      <h3>{{ s.werte.karten[0].titel }}</h3>
      <p>{{ s.werte.karten[0].text }}</p>
    </article>
    <article class="werte-item reveal">
      <span class="werte-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path pathLength="1" d="M6.4 3.5h-2A1.5 1.5 0 0 0 3 5.1C3 13.9 10.1 21 18.9 21a1.5 1.5 0 0 0 1.6-1.5v-2a1.5 1.5 0 0 0-1.3-1.5l-2.9-.4a1.5 1.5 0 0 0-1.4.6l-.9 1.2a12.6 12.6 0 0 1-5.4-5.4l1.2-.9a1.5 1.5 0 0 0 .6-1.4l-.4-2.9A1.5 1.5 0 0 0 6.4 3.5Z"/></svg>
      </span>
      <h3>{{ s.werte.karten[1].titel }}</h3>
      <p>{{ s.werte.karten[1].text }}</p>
    </article>
    <article class="werte-item reveal">
      <span class="werte-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path pathLength="1" d="M12 20.3S3.6 15.5 3.6 9.9A4.4 4.4 0 0 1 12 7.3a4.4 4.4 0 0 1 8.4 2.6c0 5.6-8.4 10.4-8.4 10.4Z"/></svg>
      </span>
      <h3>{{ s.werte.karten[2].titel }}</h3>
      <p>{{ s.werte.karten[2].text }}</p>
    </article>
  </div>
</section>

<section class="section section-tint">
  <div class="wrap wrap-breit">
    <div class="section-head reveal">
      <div>
        <p class="eyebrow">{{ s.pakete_teaser.eyebrow }}</p>
        <h2>{{ s.pakete_teaser.titel }}</h2>
      </div>
      <a class="link-arrow" href="{{ '/preise/' | url }}">{{ s.pakete_teaser.link }}</a>
    </div>
    <div class="pakete-grid">
      {%- for paket in pakete.pakete %}
      <a class="paket-card paket-card-link reveal" href="{{ '/preise/' | url }}#{{ (paket.art + '-' + paket.stufe) | lower }}">
        <span class="paket-tag">{{ paket.art }}</span>
        <h3>{{ paket.name }}</h3>
        <p>{{ paket.beschreibung }}</p>
        <span class="paket-card-foot">
          <span class="paket-preis">{{ paket.preis }}</span>
          <span class="paket-card-cta">{{ s.pakete_teaser.cta_karte }}</span>
        </span>
      </a>
      {%- endfor %}
      {%- for wp in pakete.weitere %}
      <a class="paket-card paket-card-link reveal" href="{{ '/preise/' | url }}#{{ wp.name | slugify }}">
        <span class="paket-tag">{{ wp.tag }}</span>
        <h3>{{ wp.name }}</h3>
        <p>{{ wp.beschreibung }}</p>
        <span class="paket-card-foot">
          <span class="paket-preis">{{ wp.preis }}</span>
          <span class="paket-card-cta">{{ s.pakete_teaser.cta_karte }}</span>
        </span>
      </a>
      {%- endfor %}
    </div>

    {# Auf Mobile erscheinen die Pakete stattdessen als Dropdowns wie auf der Preise-Seite #}
    <div class="pakete-akkordeon-mobil">
      {% include "pakete-akkordeon.njk" %}
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap split">
    <div class="split-media reveal">
      <img src="{{ s.wandel_teaser.bild | url }}" alt="{{ s.wandel_teaser.bild_alt }}" loading="lazy">
    </div>
    <div class="split-text reveal">
      <p class="eyebrow">{{ s.wandel_teaser.eyebrow }}</p>
      <h2>{{ s.wandel_teaser.titel }}</h2>
      <p>{{ s.wandel_teaser.text }}</p>
      <a class="link-arrow" href="{{ '/bestattung-im-wandel/' | url }}">{{ s.wandel_teaser.link }}</a>
    </div>
  </div>
</section>

<section class="cta">
  <div class="wrap center reveal">
    <div class="horizon horizon--dark" aria-hidden="true"></div>
    <h2>{{ s.cta.titel }}</h2>
    <p>{{ s.cta.text }}</p>
    <a class="cta-tel" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }}</a>
    <p class="hero-note">{{ einstellungen.erreichbarkeit }}</p>
    <div class="hero-actions">
      <a class="btn btn-ghost" href="{{ '/kontakt/' | url }}">{{ s.cta.kontakt_label }}</a>
    </div>
  </div>
</section>
