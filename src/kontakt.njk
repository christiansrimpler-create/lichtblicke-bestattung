---
layout: layout.njk
permalink: /kontakt/
active: kontakt
title: Kontakt
desc: Lichtblicke Bestattung, Tennenbacher Straße 50, 79106 Freiburg. Telefon 0761 / 27 33 44 – 24 Stunden für Sie erreichbar.
---
{% set s = seiten.kontakt %}
<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
    <p class="lead">{{ s.lead }}</p>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap kontakt-grid">
    <div class="kontakt-card reveal">
      <h2>{{ s.card_titel }}</h2>
      <ul class="kontakt-liste">
        <li>
          <span class="k-label">{{ s.labels.telefon }}</span>
          <a href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }}</a>
          <small>{{ einstellungen.erreichbarkeit }}</small>
        </li>
        <li>
          <span class="k-label">{{ s.labels.email }}</span>
          <a href="mailto:{{ einstellungen.email }}">{{ einstellungen.email }}</a>
        </li>
        <li>
          <span class="k-label">{{ s.labels.adresse }}</span>
          {{ einstellungen.adresse_name }}<br>
          {{ einstellungen.adresse_strasse }}<br>
          {{ einstellungen.adresse_ort }}
        </li>
        <li>
          <span class="k-label">{{ s.labels.oeffnungszeiten }}</span>
          {{ einstellungen.oeffnungszeiten }}
        </li>
      </ul>
      <a class="btn btn-primary" href="tel:{{ einstellungen.telefon_link }}">{{ s.button }}</a>
    </div>
    <div class="kontakt-map reveal">
      <iframe
        title="Standort von {{ einstellungen.firmenname }} auf der Karte"
        src="https://www.openstreetmap.org/export/embed.html?bbox=7.840%2C47.998%2C7.860%2C48.010&layer=mapnik&marker=48.004%2C7.850"
        loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      <a class="map-link" href="https://www.openstreetmap.org/?mlat=48.004&mlon=7.850#map=16/48.004/7.850" target="_blank" rel="noopener">{{ s.karte_link }}</a>
    </div>
  </div>
</section>
