---
layout: layout.njk
permalink: /paketfinder/
eleventyExcludeFromCollections: true
erlaubeIndexierung: false
title: Paketfinder
desc: Stellen Sie sich Ihre Bestattung in wenigen Schritten selbst zusammen.
---
{# Testseite: bewusst nicht in Navigation und Sitemap, noindex über layout.njk.
   Konfigurator: Schritte, Optionen und Preise stecken im Skript unten –
   Preise werden ergänzt, sobald die Preisliste je Option vorliegt
   (preis: null erscheint als "Preis folgt"). #}
<section class="finder">
  <div class="wrap finder-wrap"
       data-finder
       data-telefon="{{ einstellungen.telefon }}"
       data-telefon-link="{{ einstellungen.telefon_link }}"
       data-kontakt-url="{{ '/kontakt/' | url }}"
       data-preise-url="{{ '/preise/' | url }}">
    <header class="finder-kopf">
      <p class="eyebrow">Stellen Sie sich Ihren Abschied zusammen</p>
      <div class="finder-fortschritt" aria-hidden="true"><span class="finder-balken"></span></div>
      <p class="finder-zaehler"></p>
    </header>
    <div class="finder-buehne"></div>
    <noscript>
      <p>Für diese Seite wird JavaScript benötigt. Sie können sich stattdessen
      <a href="{{ '/preise/' | url }}">alle Pakete ansehen</a> oder uns direkt anrufen:
      <a href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }}</a>.</p>
    </noscript>
  </div>
</section>

<script>
(function () {
  "use strict";
  var wrap = document.querySelector("[data-finder]");
  if (!wrap) return;
  var buehne = wrap.querySelector(".finder-buehne");
  var balken = wrap.querySelector(".finder-balken");
  var zaehler = wrap.querySelector(".finder-zaehler");
  var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---- Schritte des Konfigurators ----
     typ "einzel": ein Klick wählt aus und führt weiter.
     typ "mehrfach": mehrere Optionen wählbar, "Weiter"-Button.
     "wenn" steuert Verzweigungen. "posten" ist der Name in der Zusammenstellung,
     "preis" der angezeigte Preis (null = "Preis folgt"). ---- */
  var SCHRITTE = [
    {
      id: "art",
      typ: "einzel",
      frage: "Welche Art der Bestattung suchen Sie?",
      optionen: [
        { wert: "feuer", titel: "Feuerbestattung", text: "Einäscherung und Beisetzung der Urne", posten: "Feuerbestattung – Grundleistungen", preis: null },
        { wert: "erde", titel: "Erdbestattung", text: "Beisetzung im Sarg auf einem Friedhof", posten: "Erdbestattung – Grundleistungen", preis: null }
      ]
    },
    {
      id: "anonym",
      typ: "einzel",
      frage: "Soll die Bestattung anonym erfolgen?",
      hinweis: "Bei einer anonymen Bestattung erhält das Grab keine namentliche Kennzeichnung.",
      optionen: [
        { wert: "ja", titel: "Ja", text: "Beisetzung ohne namentliche Kennzeichnung", posten: "Anonyme Beisetzung", preis: null },
        { wert: "nein", titel: "Nein", text: "Mit eigener, namentlich gekennzeichneter Grabstätte", posten: "Grabstätte mit namentlicher Kennzeichnung", preis: null }
      ]
    },
    {
      id: "feier",
      typ: "einzel",
      frage: "Wie möchten Sie Abschied nehmen?",
      wenn: function (a) { return a.anonym !== "ja"; },
      optionen: [
        { wert: "abschiedsfeier", titel: "Paket „Abschiedsfeier“", text: "Persönlich gestaltete Feier (ca. 30 Minuten) mit Musik, Dekoration und gerahmtem Foto", posten: "Paket „Abschiedsfeier“", preis: "{% for w in pakete.weitere %}{% if 'Abschiedsfeier' in w.name %}{{ w.preis }}{% endif %}{% endfor %}" },
        { wert: "individuell", titel: "Individuelle Trauerfeier", text: "Ganz nach Ihren Wünschen gestaltet – wir beraten Sie persönlich", posten: "Individuelle Trauerfeier", preis: "Preis auf Anfrage" },
        { wert: "keine", titel: "Keine Trauerfeier", text: "Stille Beisetzung im engsten Kreis", posten: "Ohne Trauerfeier (stille Beisetzung)", preis: null }
      ]
    },
    {
      id: "extras",
      typ: "mehrfach",
      frage: "Welche zusätzlichen Leistungen wünschen Sie?",
      hinweis: "Optional – Sie können mehrere Leistungen auswählen oder diesen Schritt überspringen.",
      optionen: [
        { wert: "aufbahrung", titel: "Paket „Aufbahrung im Hauptfriedhof“", text: "Persönliche Abschiednahme im Aufbahrungsraum des Hauptfriedhofs (1 Tag)", posten: "Paket „Aufbahrung im Hauptfriedhof“", preis: "{% for w in pakete.weitere %}{% if 'Aufbahrung' in w.name %}{{ w.preis }}{% endif %}{% endfor %}" },
        { wert: "blumen", titel: "Blumenschmuck", text: "Sarg- oder Urnenschmuck über unsere regionalen Partner", preis: null },
        { wert: "trauerdruck", titel: "Trauerdruck", text: "Trauerkarten und Traueranzeigen", preis: null }
      ]
    },
    {
      id: "region",
      typ: "einzel",
      frage: "Wo befindet sich der Sterbeort?",
      optionen: [
        { wert: "freiburg", titel: "In Freiburg", text: "Im Stadtgebiet Freiburg", posten: "Überführung im Stadtgebiet Freiburg", preis: null },
        { wert: "umgebung", titel: "Rund um Freiburg", text: "z. B. Gundelfingen, Denzlingen, March oder Umkirch", posten: "Überführung in Freiburg und Umgebung", preis: null },
        { wert: "weiter", titel: "Weiter entfernt", text: "Überführung innerhalb Deutschlands", posten: "Überführung innerhalb Deutschlands", preis: null }
      ]
    }
  ];

  var antworten = {};
  var verlauf = [];

  function route() {
    return SCHRITTE.filter(function (s) { return !s.wenn || s.wenn(antworten); });
  }

  function findeOption(schritt, wert) {
    for (var i = 0; i < schritt.optionen.length; i++) {
      if (schritt.optionen[i].wert === wert) return schritt.optionen[i];
    }
    return null;
  }

  /* ---- Zusammenstellung aus den gewählten Optionen ---- */
  function zusammenstellung() {
    var posten = [];
    route().forEach(function (schritt) {
      var wahl = antworten[schritt.id];
      if (schritt.typ === "mehrfach") {
        (wahl || []).forEach(function (wert) {
          var o = findeOption(schritt, wert);
          if (o) posten.push({ name: o.posten || o.titel, preis: o.preis });
        });
      } else if (wahl) {
        var o = findeOption(schritt, wahl);
        if (o) posten.push({ name: o.posten || o.titel, preis: o.preis });
      }
    });
    return posten;
  }

  /* ---- Schritt-Wechsel mit sanfter Schiebe-/Blendanimation ---- */
  function wechsel(neu, richtung) {
    var alt = buehne.firstElementChild;
    if (reduce || !alt) {
      buehne.innerHTML = "";
      buehne.appendChild(neu);
      fokussiere(neu);
      return;
    }
    alt.classList.add(richtung > 0 ? "finder-raus-links" : "finder-raus-rechts");
    setTimeout(function () {
      buehne.innerHTML = "";
      neu.classList.add(richtung > 0 ? "finder-rein-rechts" : "finder-rein-links");
      buehne.appendChild(neu);
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          neu.classList.remove("finder-rein-rechts", "finder-rein-links");
        });
      });
      fokussiere(neu);
    }, 300);
  }

  function fokussiere(schritt) {
    var kopf = schritt.querySelector("h1");
    if (kopf) { kopf.setAttribute("tabindex", "-1"); kopf.focus({ preventScroll: true }); }
  }

  function fortschritt(pos, gesamt, fertig) {
    balken.style.width = (fertig ? 100 : (pos - 1) / gesamt * 100) + "%";
    zaehler.textContent = fertig ? "Ihre Zusammenstellung" : "Schritt " + pos + " von " + gesamt;
  }

  function weiterNach(schritt) {
    var r = route();
    var i = r.indexOf(schritt);
    if (i >= 0 && i + 1 < r.length) zeigeSchritt(r[i + 1], 1);
    else zeigeErgebnis();
  }

  function zeigeSchritt(schritt, richtung) {
    var r = route();
    fortschritt(r.indexOf(schritt) + 1, r.length, false);

    var el = document.createElement("div");
    el.className = "finder-schritt";

    if (verlauf.length) {
      var zurueck = document.createElement("button");
      zurueck.type = "button";
      zurueck.className = "finder-zurueck";
      zurueck.innerHTML = "&#8592; Zurück";
      zurueck.addEventListener("click", geheZurueck);
      el.appendChild(zurueck);
    }

    var h = document.createElement("h1");
    h.className = "finder-frage";
    h.textContent = schritt.frage;
    el.appendChild(h);

    if (schritt.hinweis) {
      var p = document.createElement("p");
      p.className = "finder-hinweis";
      p.textContent = schritt.hinweis;
      el.appendChild(p);
    }

    var liste = document.createElement("div");
    liste.className = "finder-antworten";

    schritt.optionen.forEach(function (option) {
      var gewaehlt = schritt.typ === "mehrfach"
        ? (antworten[schritt.id] || []).indexOf(option.wert) !== -1
        : antworten[schritt.id] === option.wert;

      var knopf = document.createElement("button");
      knopf.type = "button";
      knopf.className = "finder-antwort" + (gewaehlt ? " gewaehlt" : "");
      knopf.innerHTML =
        "<strong>" + option.titel + "</strong>" +
        "<span>" + option.text + "</span>" +
        (option.preis ? '<em class="finder-preis">' + option.preis + "</em>" : '<em class="finder-preis finder-preis-offen">Preis folgt</em>');

      if (schritt.typ === "mehrfach") {
        knopf.setAttribute("aria-pressed", gewaehlt ? "true" : "false");
        knopf.addEventListener("click", function () {
          var wahl = antworten[schritt.id] || [];
          var pos = wahl.indexOf(option.wert);
          if (pos === -1) wahl.push(option.wert); else wahl.splice(pos, 1);
          antworten[schritt.id] = wahl;
          knopf.classList.toggle("gewaehlt");
          knopf.setAttribute("aria-pressed", knopf.classList.contains("gewaehlt") ? "true" : "false");
        });
      } else {
        knopf.addEventListener("click", function () {
          antworten[schritt.id] = option.wert;
          verlauf.push(schritt.id);
          weiterNach(schritt);
        });
      }
      liste.appendChild(knopf);
    });
    el.appendChild(liste);

    if (schritt.typ === "mehrfach") {
      var weiterZeile = document.createElement("div");
      weiterZeile.className = "finder-weiter";
      var weiter = document.createElement("button");
      weiter.type = "button";
      weiter.className = "btn btn-primary";
      weiter.textContent = "Weiter";
      weiter.addEventListener("click", function () {
        if (!antworten[schritt.id]) antworten[schritt.id] = [];
        verlauf.push(schritt.id);
        weiterNach(schritt);
      });
      weiterZeile.appendChild(weiter);
      el.appendChild(weiterZeile);
    }

    wechsel(el, richtung);
  }

  function geheZurueck() {
    var letzteId = verlauf.pop();
    var r = route();
    for (var i = 0; i < r.length; i++) {
      if (r[i].id === letzteId) { zeigeSchritt(r[i], -1); return; }
    }
    zeigeSchritt(r[0], -1);
  }

  function zeigeErgebnis() {
    var r = route();
    fortschritt(r.length, r.length, true);

    var el = document.createElement("div");
    el.className = "finder-schritt";

    var zurueck = document.createElement("button");
    zurueck.type = "button";
    zurueck.className = "finder-zurueck";
    zurueck.innerHTML = "&#8592; Zurück";
    zurueck.addEventListener("click", geheZurueck);
    el.appendChild(zurueck);

    var posten = zusammenstellung();
    var zeilen = "";
    posten.forEach(function (p) {
      zeilen += "<li><span>" + p.name + "</span><strong" + (p.preis ? "" : ' class="finder-preis-offen"') + ">" + (p.preis || "Preis folgt") + "</strong></li>";
    });

    var karte = document.createElement("div");
    karte.className = "finder-ergebnis";
    karte.innerHTML =
      '<span class="paket-tag">Ihre Auswahl</span>' +
      '<h1 class="finder-paket">Ihre Zusammenstellung</h1>' +
      "<p>So haben Sie sich den Abschied zusammengestellt – jede Position lässt sich im Gespräch noch anpassen.</p>" +
      '<ul class="finder-angaben">' + zeilen + "</ul>" +
      '<p class="finder-preis-hinweis">Ihren Gesamtpreis nennen wir Ihnen gerne in einem unverbindlichen Gespräch – rufen Sie uns an oder schreiben Sie uns.</p>' +
      '<div class="finder-aktionen">' +
      '<a class="btn btn-primary" href="' + wrap.getAttribute("data-kontakt-url") + '">Beratung anfragen</a>' +
      '<a class="btn btn-primary" href="tel:' + wrap.getAttribute("data-telefon-link") + '">' + wrap.getAttribute("data-telefon") + " anrufen</a>" +
      "</div>" +
      '<p class="finder-fuss"><a href="' + wrap.getAttribute("data-preise-url") + '">Alle Pakete ansehen</a> · <button type="button" class="finder-neustart">Neu starten</button></p>';
    el.appendChild(karte);

    karte.querySelector(".finder-neustart").addEventListener("click", function () {
      antworten = {};
      verlauf = [];
      zeigeSchritt(route()[0], -1);
    });

    wechsel(el, 1);
  }

  zeigeSchritt(route()[0], 1);
})();
</script>
