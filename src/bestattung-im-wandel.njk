---
layout: layout.njk
permalink: /bestattung-im-wandel/
active: wandel
title: Bestattung im Wandel
desc: Warum preiswerte, würdevolle Bestattungen dem Zeitgeist entsprechen – das Konzept von Lichtblicke Bestattung in Freiburg.
---
{% set s = seiten.wandel %}
<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap narrow prose reveal">
    {%- for absatz in s.absaetze %}
    <p>{{ absatz }}</p>
    {%- endfor %}

    <blockquote class="pull-quote">
      {{ s.pull_quote }}
    </blockquote>

    <div class="info-callout">
      <strong>{{ s.callout.titel }}</strong>
      <a class="btn btn-primary" href="{{ '/kontakt/' | url }}">{{ s.callout.button }}</a>
    </div>
  </div>
</section>
