---
layout: layout.njk
permalink: /preise/
active: preise
title: Pakete & Preise
desc: Transparente Bestattungspakete von Lichtblicke Bestattung – Feuer- und Erdbestattung als StandardPaket sowie Komfortpaket Anonyme Bestattung, ab 2.250 € inkl. MwSt. Klare Leistungen, faire Preise.
---
{% set s = seiten.preise %}
<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
    <p class="lead">{{ s.lead }}</p>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap wrap-breit">
    {# Reihenfolge kommt aus pakete.yaml – dort umsortieren, nicht hier #}
    <div class="pakete-akkordeon">
    {%- for paket in pakete.pakete %}
    <details class="paket-acc reveal" id="{{ (paket.art + '-' + paket.stufe) | lower }}">
      <summary class="paket-acc-head">
        <span class="paket-acc-info">
          <span class="paket-tag">{{ paket.art }} · {{ paket.stufe }}</span>
          <span class="paket-acc-name">{{ paket.name }}</span>
          <span class="paket-acc-desc">{{ paket.beschreibung }}</span>
        </span>
        <span class="paket-acc-right">
          <span class="paket-acc-preis-wrap">
            <span class="paket-preis">{{ paket.preis }}</span>
            <small>{{ paket.preis_zusatz }}</small>
          </span>
          <span class="paket-acc-toggle">
            <span class="paket-acc-toggle-label">{{ s.toggle_label }}</span>
            <svg class="paket-acc-chevron" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </span>
        </span>
      </summary>
      <div class="paket-acc-body">
        <div class="paket-acc-cols">
          <div>
            <h3 class="paket-sub">{{ s.spalte_leistungen }}</h3>
            <ul class="paket-leistungen">
              {%- for l in paket.leistungen %}
              <li>{{ l }}</li>
              {%- endfor %}
            </ul>
          </div>
          <div>
            <h3 class="paket-sub">{{ s.spalte_lieferungen }}</h3>
            <ul class="paket-leistungen">
              {%- for l in paket.lieferungen %}
              <li>{{ l }}</li>
              {%- endfor %}
            </ul>
          </div>
        </div>
        {%- if paket.hinweis %}
        <p class="paket-hinweis">{{ paket.hinweis }}</p>
        {%- endif %}
        <a class="btn btn-primary" href="{{ '/kontakt/' | url }}">{{ s.button_paket }}</a>
      </div>
    </details>
    {%- endfor %}
    </div>

    {%- set wp = pakete.wunschpaket %}
    <article class="paket-breit reveal" id="wunschpaket">
      <div class="paket-breit-info">
        <span class="paket-tag">{{ wp.tag }}</span>
        <h2 class="paket-breit-name">{{ wp.name }}</h2>
        <p>{{ wp.beschreibung }}</p>
        <p>{{ wp.text }}</p>
      </div>
      <div class="paket-breit-aktion">
        <span class="paket-preis">{{ wp.preis }}</span>
        <a class="btn btn-primary" href="{{ '/kontakt/' | url }}">{{ s.button_paket }}</a>
      </div>
    </article>
  </div>

  <div class="wrap narrow reveal">
    <p class="preis-fussnote">
      {%- for zeile in s.fussnote %}
      <span>{{ zeile }}</span>
      {%- endfor %}
    </p>
  </div>

  <div class="wrap narrow center reveal">
    <p class="muted">{{ s.schluss }}</p>
    <a class="btn btn-primary" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }} anrufen</a>
  </div>
</section>
