<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} · {{ einstellungen.firmenname }}</title>
  <meta name="description" content="{{ desc }}">
  <link rel="icon" href="{{ '/assets/img/logo-kreis.png' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}?v={{ assetVersion }}">
</head>
<body>

  <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>

  <header class="site-header">
    <div class="wrap header-inner">
      <a class="brand" href="{{ '/' | url }}" aria-label="{{ einstellungen.firmenname }} – Startseite">
        <img src="{{ '/assets/img/logo.png' | url }}" alt="{{ einstellungen.firmenname }}" width="220" height="60">
      </a>
      <nav class="main-nav" aria-label="Hauptnavigation">
        <ul>
          <li><a href="{{ '/' | url }}"{% if active == "start" %} aria-current="page"{% endif %}>Startseite</a></li>
          <li><a href="{{ '/ueber-uns/' | url }}"{% if active == "ueber-uns" %} aria-current="page"{% endif %}>Über uns</a></li>
          <li><a href="{{ '/preise/' | url }}"{% if active == "preise" %} aria-current="page"{% endif %}>Preise</a></li>
          <li><a href="{{ '/bestattung-im-wandel/' | url }}"{% if active == "wandel" %} aria-current="page"{% endif %}>Bestattung im Wandel</a></li>
          <li><a href="{{ '/kontakt/' | url }}"{% if active == "kontakt" %} aria-current="page"{% endif %}>Kontakt</a></li>
        </ul>
      </nav>
      <a class="btn btn-call nav-call" href="tel:{{ einstellungen.telefon_link }}">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.58 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .58 3.6 1 1 0 0 1-.25 1z"/></svg>
        <span>{{ einstellungen.telefon }}</span>
      </a>
      <button class="burger" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-head">
      <a class="brand" href="{{ '/' | url }}"><img src="{{ '/assets/img/logo.png' | url }}" alt="{{ einstellungen.firmenname }}" width="200" height="55"></a>
      <button class="menu-close" aria-label="Menü schließen">✕</button>
    </div>
    <nav aria-label="Mobile Navigation">
      <ul>
        <li><a href="{{ '/' | url }}"{% if active == "start" %} aria-current="page"{% endif %}>Startseite</a></li>
        <li><a href="{{ '/ueber-uns/' | url }}"{% if active == "ueber-uns" %} aria-current="page"{% endif %}>Über uns</a></li>
        <li><a href="{{ '/preise/' | url }}"{% if active == "preise" %} aria-current="page"{% endif %}>Preise</a></li>
        <li><a href="{{ '/bestattung-im-wandel/' | url }}"{% if active == "wandel" %} aria-current="page"{% endif %}>Bestattung im Wandel</a></li>
        <li><a href="{{ '/kontakt/' | url }}"{% if active == "kontakt" %} aria-current="page"{% endif %}>Kontakt</a></li>
      </ul>
    </nav>
    <div class="mobile-menu-foot">
      <a class="btn btn-call" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }} anrufen</a>
      <p>{{ einstellungen.erreichbarkeit }}</p>
    </div>
  </div>

  <main id="inhalt">
{{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="wrap footer-main">
      <div class="footer-brand">
        <img src="{{ '/assets/img/logo.png' | url }}" alt="{{ einstellungen.firmenname }}" width="220" height="60" class="footer-logo">
        <p>{{ einstellungen.footer_text }}</p>
      </div>
      <div>
        <h4>Seiten</h4>
        <ul>
          <li><a href="{{ '/ueber-uns/' | url }}">Über uns</a></li>
          <li><a href="{{ '/preise/' | url }}">Preise</a></li>
          <li><a href="{{ '/bestattung-im-wandel/' | url }}">Bestattung im Wandel</a></li>
          <li><a href="{{ '/kontakt/' | url }}">Kontakt</a></li>
        </ul>
      </div>
      <div>
        <h4>Kontakt</h4>
        <ul class="footer-kontakt">
          <li>{{ einstellungen.adresse_name }}</li>
          <li>{{ einstellungen.adresse_strasse }}</li>
          <li>{{ einstellungen.adresse_ort }}</li>
          <li><a href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }}</a></li>
          <li><a href="mailto:{{ einstellungen.email }}">{{ einstellungen.email }}</a></li>
          <li class="erreichbar">{{ einstellungen.erreichbarkeit }}</li>
        </ul>
      </div>
    </div>
    <div class="wrap footer-legal">
      <span>© {% year %} {{ einstellungen.firmenname }} · Eine Marke der {{ einstellungen.mutter_name }}</span>
      <span class="footer-legal-links">
        <a href="{{ '/impressum/' | url }}">Impressum</a>
        <a href="{{ '/datenschutz/' | url }}">Datenschutz</a>
      </span>
    </div>
  </footer>

  <script src="{{ '/assets/js/main.js' | url }}?v={{ assetVersion }}"></script>
</body>
</html>
