---
layout: layout.njk
permalink: /impressum/
active: ""
title: Impressum
desc: Impressum von Lichtblicke Bestattung – eine Marke der Müller Bestattungen GmbH, Freiburg.
---
{% set s = seiten.impressum %}
<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap narrow prose reveal">
    <h2>{{ s.h_angaben }}</h2>
    <p>
      {{ einstellungen.firmenname }}<br>
      {{ einstellungen.adresse_strasse }}<br>
      {{ einstellungen.adresse_ort }}<br>
      Telefon: {{ einstellungen.telefon }}<br>
      E-Mail: <a href="mailto:{{ einstellungen.email }}">{{ einstellungen.email }}</a>
    </p>

    <h2>{{ s.h_marke }}</h2>
    <p>
      {{ einstellungen.mutter_name }}<br>
      {{ einstellungen.mutter_strasse }}<br>
      {{ einstellungen.mutter_ort }}<br>
      Geschäftsführung: {{ einstellungen.mutter_gf }}<br>
      {{ einstellungen.mutter_hrb }}<br>
      USt-ID-Nr.: {{ einstellungen.mutter_ustid }}
    </p>

    <h2>{{ s.h_verantwortlich }}</h2>
    <p>{{ einstellungen.verantwortlich }}</p>

    <h2>{{ s.h_odr }}</h2>
    <p>{{ s.odr_text_1 }}
      <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener">https://ec.europa.eu/consumers/odr/</a>.</p>
    <p>{{ s.odr_text_2 }}</p>
  </div>
</section>
