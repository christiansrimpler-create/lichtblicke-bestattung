---
layout: layout.njk
permalink: /ueber-uns/
active: ueber-uns
title: Über uns
desc: Lichtblicke Bestattung in Freiburg – transparente Beratung rund um Vorsorge, Sterben, Bestatten und Trauerbegleitung. Eine Marke der Müller Bestattungen GmbH.
---
{% set s = seiten.ueberuns %}
{%- if s.bild %}
{# Bild liegt hinter der ganzen Seite (bis zum Footer), Overlay siehe .bild-seite #}
<div class="bild-seite">
  <div class="bild-seite-bg" aria-hidden="true" style="background-image: url('{{ s.bild | url }}');"></div>
{%- endif %}

<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap narrow prose reveal">
    <p class="lead">{{ s.lead }}</p>

    {%- for absatz in s.absaetze %}
    <p>{{ absatz }}</p>
    {%- endfor %}

    <div class="info-callout">
      <strong>{{ einstellungen.erreichbarkeit }}</strong>
      <a class="btn btn-primary" href="tel:{{ einstellungen.telefon_link }}">{{ einstellungen.telefon }} anrufen</a>
    </div>

    <p class="muted">{{ s.schluss }}</p>
  </div>
</section>

{%- if s.bild %}
</div>
{%- endif %}
