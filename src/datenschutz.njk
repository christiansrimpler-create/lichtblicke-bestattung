---
layout: layout.njk
permalink: /datenschutz/
active: ""
title: Datenschutzerklärung
desc: Datenschutzerklärung von Lichtblicke Bestattung, Freiburg.
---
{% set s = seiten.datenschutz %}
<section class="page-head">
  <div class="wrap narrow reveal">
    <p class="eyebrow">{{ s.eyebrow }}</p>
    <h1>{{ s.titel }}</h1>
  </div>
</section>

<section class="section pt-0">
  <div class="wrap narrow prose reveal">
    <h2>{{ s.h_verantwortlich }}</h2>
    <p>
      {{ einstellungen.firmenname }}<br>
      {{ einstellungen.adresse_strasse }}, {{ einstellungen.adresse_ort }}<br>
      Eine Marke der {{ einstellungen.mutter_name }},
      {{ einstellungen.mutter_strasse }}, {{ einstellungen.mutter_ort }}.<br>
      Verantwortlich: {{ einstellungen.verantwortlich }} ·
      <a href="mailto:{{ einstellungen.email }}">{{ einstellungen.email }}</a>
    </p>

    {%- for abschnitt in s.abschnitte %}
    <h2>{{ abschnitt.heading }}</h2>
    <p>{{ abschnitt.text }}</p>
    {%- endfor %}

    <p class="muted">{{ s.hinweis }}</p>
  </div>
</section>
